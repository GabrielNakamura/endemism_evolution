{
  "name": "RStudio Environment",
  "image": "rocker/rstudio:latest",
  "containerUser": "root",
  "remoteUser": "root",
  "forwardPorts": [8787],
  "portsAttributes": {
    "8787": {
      "label": "RStudio Server",
      "onAutoForward": "openBrowser",
      "visibility": "public"
    }
  },
  "postCreateCommand": "if [ -f install.R ]; then Rscript install.R; fi"
}